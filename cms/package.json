{
  "name": "explore-dubuque-cms",
  "version": "1.0.0",
  "description": "Payload CMS for ExploreDubuque.com",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "build": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload build",
    "start": "cross-env PAYLOAD_CONFIG_PATH=dist/payload.config.js node dist/server.js",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types"
  },
  "dependencies": {
    "payload": "2.31.0",
    "@payloadcms/db-postgres": "2.7.0",
    "@payloadcms/richtext-lexical": "2.13.0",
    "@payloadcms/bundler-webpack": "2.2.1",
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
