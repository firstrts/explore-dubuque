# Payload CMS Environment Variables
# Copy to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URI=postgresql://payload:yourpassword@localhost:5432/explore_dubuque

# Payload secret (generate a strong random string)
PAYLOAD_SECRET=your-super-secret-key-change-this

# Public URL of the CMS (used for media URLs, CORS, etc.)
PAYLOAD_PUBLIC_SERVER_URL=https://ExploreDubuque.com

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# CORS — Next.js frontend origin
CORS_URLS=https://ExploreDubuque.com,http://localhost:3000
